<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="in.ayurzenix.app.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_chat"
        android:name="in.ayurzenix.app.ui.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat" />

    <fragment
        android:id="@+id/navigation_wallet"
        android:name="in.ayurzenix.app.ui.WalletFragment"
        android:label="Wallet"
        tools:layout="@layout/fragment_wallet" />

    <fragment
        android:id="@+id/navigation_body_scan"
        android:name="in.ayurzenix.app.ui.BodyScanFragment"
        android:label="AI Body Scan"
        tools:layout="@layout/fragment_body_scan" />

    <fragment
        android:id="@+id/navigation_daily_routine"
        android:name="in.ayurzenix.app.ui.home.DailyRoutineFragment"
        android:label="Daily Ayur Routine"
        tools:layout="@layout/fragment_daily_routine" />

</navigation>
